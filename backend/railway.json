{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "/backend/**",
      "/docs/**",
      "/README.md"
    ]
  },
  "deploy": {
    "startCommand": "api",
    "preDeployCommand": [
      "migrate"
    ],
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
